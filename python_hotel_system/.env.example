# Flask
SECRET_KEY=replace-with-a-long-random-secret-key
FLASK_ENV=development
FLASK_DEBUG=True

# Database
DATABASE_URL=sqlite:///hotel.db

# Frontend origins and cookie behavior
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=False

# SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-smtp-username@example.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-smtp-username@example.com
HOTEL_EMAIL=hotel@example.com
ADMIN_EMAILS=owner@example.com

# Admin bootstrap account
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD_HASH=replace-with-werkzeug-password-hash
ADMIN_BOOTSTRAP_FULL_NAME=Hotel Admin
ADMIN_BOOTSTRAP_PHONE=+962700000000
ADMIN_BOOTSTRAP_COUNTRY=Jordan
